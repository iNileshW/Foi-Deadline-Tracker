# Copy to `.env` and load with your shell (`set -a; . ./.env; set +a`)
# or via a process supervisor. `.env` itself is gitignored.

# REQUIRED in production. Generate with:
#   python -c 'import secrets; print(secrets.token_hex(32))'
FOI_SECRET_KEY=

# Local development only. When set to 1 and FOI_SECRET_KEY is unset,
# the app generates an ephemeral per-process secret. Sessions do not
# survive a restart. Never set this in production.
# FOI_ALLOW_INSECURE_DEV_SECRET=1

# Werkzeug debugger. Default off. Never enable in production.
# FLASK_DEBUG=1

# Optional overrides.
# FOI_DB=foi.db
# PORT=5002
